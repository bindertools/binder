# Wails build/watcher ignore file — same syntax as .gitignore
# Excludes non-essential files from the Wails dev watcher and build packaging.

# Built binary (dev artifact sitting in app/)
terminal-ide.exe
terminal-ide

# Sub-module / sub-package documentation and metadata
# (go.mod in sub-packages is not the root module — not needed by the build)
bash/README.md
bash/go.mod
bash/LICENSE
zsh/README.md
zsh/go.mod
zsh/LICENSE
powershell/README.md
powershell/go.mod
powershell/LICENSE
terminal/README.md
terminal/go.mod
terminal/go.sum
terminal/LICENSE
plugins/README.md
plugins/go.mod
plugins/LICENSE

# Plugin SDK source tree (only the compiled Go output is used)
plugins/src/

# Test data and local dev files
**/*_test.go
**/*.test

# OS / editor noise
.DS_Store
Thumbs.db
**/.idea/
**/.vscode/
